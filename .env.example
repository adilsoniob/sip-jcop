# ============================================
# JCopSIP - Root Configuration
# ============================================

# Backend
BACKEND_PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/jcopsip

# Security
SESSION_SECRET=change-this-to-a-secure-random-string
JWT_SECRET=change-this-to-a-secure-random-string

# Master Panel (NextBilling)
MASTER_PANEL_URL=https://sip.avoip.com.br
MASTER_PANEL_USER=your-master-panel-username
MASTER_PANEL_PASSWORD=your-master-panel-password

# Frontend
FRONTEND_URL=http://localhost:5173
