# ============================================
# JCopSIP - Backend Configuration
# ============================================

# Server
PORT=3001
NODE_ENV=production

# Database (PostgreSQL) - leave empty for file-based mode
DATABASE_URL=

# Session
SESSION_SECRET=change-this-to-a-random-secret
SESSION_TIMEOUT=86400000

# JWT
JWT_SECRET=change-this-to-a-random-jwt-secret
JWT_EXPIRES_IN=24h

# Master Panel (AVOIP SIP) Credentials
MASTER_PANEL_URL=https://sip.avoip.com.br
MASTER_PANEL_USER=your_master_user
MASTER_PANEL_PASSWORD=your_master_password

# Frontend URL (for CORS) - comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173,https://sip-jcop.edgeone.run